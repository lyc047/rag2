# ============================================================
# RAG2 配置文件
# 复制此文件为 .env 并修改其中的配置项
#   cp .env.example .env
# ============================================================

# LLM配置 —— 选择你要用的大模型
# 可选: DEEPSEEK / OLLAMA / ALIYUN
LLM_TYPE=DEEPSEEK

# DeepSeek 配置（LLM_TYPE=DEEPSEEK 时需要）
# 去 https://platform.deepseek.com 注册获取 API Key
DEEPSEEK_API_KEY=在此填入你的DeepSeek_API_Key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat

# Ollama 配置（LLM_TYPE=OLLAMA 时需要，使用本地模型）
# OLLAMA_CHAT_MODEL=qwen3:latest
# OLLAMA_BASE_URL=http://localhost:11434

# 嵌入模型配置
# 当前仅支持 OLLAMA 嵌入
EMBED_MODEL_TYPE=OLLAMA
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b

# SQLite数据库路径（一般不需要改）
DATABASE_URL=sqlite+aiosqlite:///data/rag2.db

# ChromaDB向量库路径（一般不需要改）
CHROMA_PERSIST_PATH=data/chromadb
CHROMA_COLLECTION=rag2_collection
CHROMA_CHUNK_SIZE=500
CHROMA_CHUNK_OVERLAP=50

# 知识库文件存储路径
DATA_PATH=data/knowledge

# 检索配置
TOP_K=5
BM25_WEIGHT=0.3

# LLM重排序开关（true/false）
RERANK_ENABLED=true

# 服务端口
SERVER_PORT=8005
